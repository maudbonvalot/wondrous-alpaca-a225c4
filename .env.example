# ========================================
# VARIABLES D'ENVIRONNEMENT - EXEMPLE
# ========================================
# 
# IMPORTANT : 
# 1. Copie ce fichier et renomme-le en ".env" (sans le .example)
# 2. Remplace toutes les valeurs XXXXXXXXXX par tes vraies clés
# 3. NE COMMITTE JAMAIS le fichier .env (il est déjà dans .gitignore)
# 
# ========================================

# ─── STRIPE (Clés de TEST pour le développement) ───────────────────
# Où trouver : https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXX

# Webhook Secret (généré par Stripe CLI en local)
# En local : lance `stripe listen` et copie le whsec_ affiché
# En prod : va sur https://dashboard.stripe.com/webhooks et copie le signing secret
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXX

# ID du produit "Reset Métabolique" (pour filtrer les paiements)
# Où trouver : https://dashboard.stripe.com/products
# Clique sur ton produit → copie l'ID qui commence par "prod_"
STRIPE_PRODUCT_ID=prod_XXXXXXXXXX

# ─── AUTH0 ──────────────────────────────────────────────────────────
# Où trouver : https://manage.auth0.com/dashboard

# Machine-to-Machine Application (pour créer utilisateurs ET authentifier)
# Où trouver : Applications → Ton M2M app → Settings
# IMPORTANT : Active les Grant Types "Password" + "Client Credentials"
AUTH0_M2M_CLIENT_ID=XXXXXXXXXX
AUTH0_M2M_CLIENT_SECRET=XXXXXXXXXX

# ─── SENDGRID ───────────────────────────────────────────────────────
# Où trouver : https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXX

# Email expéditeur (doit être vérifié dans SendGrid)
# Où configurer : Settings → Sender Authentication
EMAIL_FROM=ton-email@gmail.com

# Template SendGrid pour l'email transactionnel de credentials
# Créé dans : Email API → Dynamic Templates
# REQUIS : Ce template doit exister pour que l'email parte
SENDGRID_TEMPLATE_CREDENTIALS=d-XXXXXXXXXX

# ID de la liste Marketing pour déclencher l'automation
# Créé dans : Marketing → Contacts → Lists
# Cette liste déclenche automatiquement la séquence d'emails nurturing
SENDGRID_MARKETING_LIST_ID=XXXXXXXXXX

# ─── SITE ───────────────────────────────────────────────────────────
# URL racine de ton site (change selon l'environnement)
# En local : http://localhost:8888
# En prod : https://ton-site.netlify.app
ROOT_URL=http://localhost:8888

